<UserControl x:Class="AlgebraOfSignatures.WPF.Controls.MatrixControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AlgebraOfSignatures.WPF.Controls"
             xmlns:converters="clr-namespace:AlgebraOfSignatures.WPF.Converters"
             mc:Ignorable="d"
             FontSize="17">
    <Grid>
        <DataGrid
            AutoGenerateColumns="True"
            HorizontalScrollBarVisibility="Auto"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            SelectionUnit="Cell"
            SelectionMode="Extended"
            ColumnWidth="40"
            RowHeight="40"
            ColumnHeaderHeight="35"
            RowHeaderWidth="35"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="Transparent"
            AlternatingRowBackground="Transparent">
            <DataGrid.ItemsSource>
                <MultiBinding
                    Converter="{converters:ArrayToDataTableConverter}"
                    UpdateSourceTrigger="PropertyChanged">
                    <Binding Mode="OneWay" 
                             Path="UniformHyperGraph.Signature.Value"
                             RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=local:MatrixControl}"/>
                    
                </MultiBinding>
            </DataGrid.ItemsSource>
            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">

                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>

                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                       Path=AlternationIndex,
                                       StringFormat=V{0}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>

                </Style>
            </DataGrid.RowHeaderStyle>
        
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Setter Property="AlternationCount" Value="1000000"/>
                </Style>
            </DataGrid.Style>
        
        </DataGrid>
    </Grid>
</UserControl>
