<UserControl x:Class="AlgebraOfSignatures.WPF.Controls.MatrixControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AlgebraOfSignatures.WPF.Controls"
             xmlns:converters="clr-namespace:DistributedSystems.LaboratoryWork.Nuget.Converters;assembly=DistributedSystems.LaboratoryWork.Nuget"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d"
             FontSize="17">
    <UserControl.Resources>
        <Style TargetType="xctk:IntegerUpDown">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
            <Setter Property="Padding" Value="0, -1, 0, 0"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <system:Int32 x:Key="One">1</system:Int32>
    </UserControl.Resources>
    <Grid HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid 
            Grid.Row="0"
            HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                HorizontalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding Indices, RelativeSource={RelativeSource AncestorType=local:MatrixControl}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <xctk:IntegerUpDown 
                                Value="{Binding Value, Mode=TwoWay}">
                                <xctk:IntegerUpDown.Maximum>
                                    <MultiBinding
                                        Converter="{converters:ArithmeticConverter}"
                                        ConverterParameter="{x:Static converters:ArithmeticConverter+Operators.Minus}">
                                        <Binding 
                                            RelativeSource="{RelativeSource AncestorType=local:MatrixControl}"
                                            Path="RowsCount"/>
                                        <Binding>
                                            <Binding.Source>
                                                <system:Int32>1</system:Int32>
                                            </Binding.Source>
                                        </Binding>
                                    </MultiBinding>
                                </xctk:IntegerUpDown.Maximum>
                            </xctk:IntegerUpDown>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <Button
                Grid.Column="1"
                Command="{Binding ShowGraphCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MatrixControl}}"
                CommandParameter="True"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="Blue"
                FontStyle="Italic"
                Content="fx">
                <Button.Visibility>
                    <MultiBinding Converter="{converters:FromBoolConverter}">
                        <Binding RelativeSource="{RelativeSource AncestorType=local:MatrixControl}" Path="IsDrawGraphButtonVisible"/>
                        <Binding>
                            <Binding.Source>
                                <Visibility>Visible</Visibility>
                            </Binding.Source>
                        </Binding>
                        <Binding>
                            <Binding.Source>
                                <Visibility>Collapsed</Visibility>
                            </Binding.Source>
                        </Binding>
                    </MultiBinding>
                </Button.Visibility>
            </Button>
            <Button
                Grid.Column="2"
                Command="{Binding SaveCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:MatrixControl}}"
                CommandParameter="True"
                FontSize="17"
                FontWeight="SemiBold"
                Foreground="Green"
                Content="✓">
                <Button.Visibility>
                    <MultiBinding Converter="{converters:FromBoolConverter}">
                        <Binding RelativeSource="{RelativeSource AncestorType=local:MatrixControl}" Path="IsReadOnly"/>
                        <Binding>
                            <Binding.Source>
                                <Visibility>Collapsed</Visibility>
                            </Binding.Source>
                        </Binding>
                        <Binding>
                            <Binding.Source>
                                <Visibility>Visible</Visibility>
                            </Binding.Source>
                        </Binding>
                    </MultiBinding>
                </Button.Visibility>
            </Button>
        </Grid>
        <DataGrid
            Grid.Row="2"
            ItemsSource="{Binding MatrixDataTable, RelativeSource={RelativeSource AncestorType=local:MatrixControl}}"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            AutoGenerateColumns="True"
            HorizontalScrollBarVisibility="Auto"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserSortColumns="False"
            CanUserReorderColumns="False"
            IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=local:MatrixControl}}"
            SelectionUnit="Cell"
            SelectionMode="Extended"
            ColumnWidth="60"
            RowHeight="30"
            ColumnHeaderHeight="30"
            RowHeaderWidth="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            SelectedItem="{Binding SelectedCellValue, RelativeSource={RelativeSource AncestorType=local:MatrixControl}, Mode=TwoWay}"
            Background="Transparent"
            SelectedCellsChanged="DataGrid_SelectedCellsChanged">
            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                       Path=AlternationIndex,
                                       StringFormat=V{0}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Setter Property="AlternationCount" Value="1000000"/>
                </Style>
            </DataGrid.Style>
        </DataGrid>
    </Grid>
</UserControl>
