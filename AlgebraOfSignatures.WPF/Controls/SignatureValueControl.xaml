<UserControl x:Class="AlgebraOfSignatures.WPF.Controls.SignatureValueControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AlgebraOfSignatures.WPF.Controls"
             mc:Ignorable="d"
             FontSize="15">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBox
            Grid.Column="0"
            Text="{Binding SignatureFirstValue, 
                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:SignatureValueControl}, 
                Mode=TwoWay}"
            TextAlignment="Center"
            Foreground="DimGray"
            HorizontalContentAlignment="Center"/>
        <Button 
            Content="Обновить"
            Grid.Column="1"/>
    </Grid>
</UserControl>
