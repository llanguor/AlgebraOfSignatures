<Page x:Class="AlgebraOfSignatures.WPF.View.Pages.ConversionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:AlgebraOfSignatures.WPF.View.Pages"
      xmlns:converters="clr-namespace:AlgebraOfSignatures.WPF.Converters"
      xmlns:controls="clr-namespace:AlgebraOfSignatures.WPF.Controls"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      mc:Ignorable="d"
      Title="ConversionPage"
      FontSize="15"
      Foreground="#111827"
      Background="#FFFFFF">
    <Page.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style TargetType="xctk:IntegerUpDown">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#94A3B8"
                BorderThickness="1.3"
                CornerRadius="12"
                Padding="14">
            <WrapPanel>
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Количество вершин"/>
                    <xctk:IntegerUpDown 
                        Value="{Binding VertexCount}"
                        Minimum="1"
                        Width="170"/>
                </StackPanel>
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Степень однородности"/>
                    <xctk:IntegerUpDown 
                        Minimum="2"
                        Value="{Binding UniformityDegree}"
                        Width="170"/>
                </StackPanel>
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Исходное представление"/>
                    <ComboBox Width="170"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Целевое представление"/>
                    <ComboBox Width="170"/>
                </StackPanel>
            </WrapPanel>
        </Border>


        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    BorderBrush="#94A3B8"
                    BorderThickness="1.3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Сигнатура"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               Foreground="#0F172A"/>
                    <controls:UniformHyperGraphControl 
                        Grid.Row="1"
                        SelectedCellValue="{Binding SelectedCellValue, Mode=TwoWay}"
                        ShowGraphCommand="{Binding ShowGraphCommand, Mode=OneWay}"
                        IsReadOnly="False"
                        UniformHyperGraph="{Binding UniformHyperGraph, Mode=OneWay}"
                        RepresentationToVisualize="Signature"/>
                    <StackPanel 
                        Grid.Row="2"
                        Orientation="Vertical"
                        Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Выбранное значение" Width="180"/>
                            <TextBlock Text="{Binding SelectedCellValue}"/>
                        </StackPanel>
                        <StackPanel 
                            Orientation="Horizontal"
                            Margin="0,6,0,0">
                            <TextBlock Text="Битовое представление" Width="180"/>
                            <TextBlock 
                                Text="{Binding SelectedCellValue,
                                Converter={converters:LongToBitsConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="True"
                          Cursor="SizeWE"/>
            
            <Border Grid.Column="2"
                    BorderBrush="#94A3B8"
                    BorderThickness="1.3">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Матрица смежности"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               Foreground="#0F172A"/>
                    <controls:UniformHyperGraphControl
                        ShowGraphCommand="{Binding ShowGraphCommand, Mode=OneWay}"
                        IsReadOnly="True"
                        UniformHyperGraph="{Binding UniformHyperGraph, Mode=OneWay}"
                        RepresentationToVisualize="AdjacencyMatrix"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>